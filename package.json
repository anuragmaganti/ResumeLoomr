{
  "name": "cvapplication",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "check:architecture": "node scripts/verifyArchitecture.mjs",
    "check:dead-code": "knip --no-progress",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test --test-concurrency=1",
    "verify": "npm run check:architecture && npm run check:dead-code && npm run lint && npm test && npm run audit:production && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.13.0",
    "@vercel/analytics": "^1.6.1",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "idb": "^8.0.3",
    "mammoth": "^1.12.0",
    "motion": "^12.42.2",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "knip": "6.29.0",
    "vite": "^7.2.4"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
