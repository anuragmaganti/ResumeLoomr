rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // The browser uses the authenticated Vercel sync API for every mutation.
    // Keeping client access read-only prevents bypassing server normalization.
    match /users/{uid}/workspace/main {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /users/{uid}/resumes/{resumeId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
