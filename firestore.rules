rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isString(value) {
      return value is string;
    }

    function isNullableString(value) {
      return value == null || value is string;
    }

    function isValidTemplate(value) {
      return value in ['modern', 'executive', 'compact'];
    }

    function isValidSectionOrder(sectionOrder) {
      return sectionOrder is list &&
        sectionOrder.size() >= 1 &&
        sectionOrder.size() <= 11 &&
        sectionOrder.hasOnly([
          'personal',
          'education',
          'experience',
          'skills',
          'projects',
          'certifications',
          'volunteering',
          'leadership',
          'languages',
          'awards',
          'publications'
        ]);
    }

    function isValidSetting(value) {
      return value is int && value >= -5 && value <= 5;
    }

    function isValidSettings(settings) {
      return settings is map &&
        settings.keys().hasOnly([
          'textSize',
          'horizontalMargins',
          'verticalMargins',
          'lineSpacing',
          'sectionSpacing',
          'entrySpacing',
          'headingSize',
          'nameSize'
        ]) &&
        isValidSetting(settings.textSize) &&
        isValidSetting(settings.horizontalMargins) &&
        isValidSetting(settings.verticalMargins) &&
        isValidSetting(settings.lineSpacing) &&
        isValidSetting(settings.sectionSpacing) &&
        isValidSetting(settings.entrySpacing) &&
        isValidSetting(settings.headingSize) &&
        isValidSetting(settings.nameSize);
    }

    function isValidMeta(meta, resumeIds) {
      return meta is map &&
        meta.keys().hasAll(resumeIds) &&
        meta.keys().hasOnly(resumeIds);
    }

    function isValidResumeCollection(value) {
      return value is list && value.size() <= 100;
    }

    function isValidSectionBlockKind(value) {
      return value in [
        'education',
        'roles',
        'skills',
        'projects',
        'certifications',
        'languages',
        'awards',
        'publications',
        'custom'
      ];
    }

    function isValidSectionBlock(section) {
      return section is map &&
        section.keys().hasOnly([
          'id',
          'kind',
          'title',
          'legacySectionId',
          'entries'
        ]) &&
        isString(section.id) &&
        section.id.size() > 0 &&
        section.id.size() <= 100 &&
        section.id != 'personal' &&
        isString(section.kind) &&
        isValidSectionBlockKind(section.kind) &&
        isString(section.title) &&
        section.title.size() > 0 &&
        section.title.size() <= 80 &&
        isString(section.legacySectionId) &&
        section.legacySectionId.size() <= 32 &&
        section.entries is list &&
        section.entries.size() <= 100;
    }

    function isValidSectionBlocks0To7(sections) {
      return (sections.size() <= 0 || isValidSectionBlock(sections[0])) &&
        (sections.size() <= 1 || isValidSectionBlock(sections[1])) &&
        (sections.size() <= 2 || isValidSectionBlock(sections[2])) &&
        (sections.size() <= 3 || isValidSectionBlock(sections[3])) &&
        (sections.size() <= 4 || isValidSectionBlock(sections[4])) &&
        (sections.size() <= 5 || isValidSectionBlock(sections[5])) &&
        (sections.size() <= 6 || isValidSectionBlock(sections[6])) &&
        (sections.size() <= 7 || isValidSectionBlock(sections[7]));
    }

    function isValidSectionBlocks8To15(sections) {
      return (sections.size() <= 8 || isValidSectionBlock(sections[8])) &&
        (sections.size() <= 9 || isValidSectionBlock(sections[9])) &&
        (sections.size() <= 10 || isValidSectionBlock(sections[10])) &&
        (sections.size() <= 11 || isValidSectionBlock(sections[11])) &&
        (sections.size() <= 12 || isValidSectionBlock(sections[12])) &&
        (sections.size() <= 13 || isValidSectionBlock(sections[13])) &&
        (sections.size() <= 14 || isValidSectionBlock(sections[14])) &&
        (sections.size() <= 15 || isValidSectionBlock(sections[15]));
    }

    function isValidSectionBlocks16To23(sections) {
      return (sections.size() <= 16 || isValidSectionBlock(sections[16])) &&
        (sections.size() <= 17 || isValidSectionBlock(sections[17])) &&
        (sections.size() <= 18 || isValidSectionBlock(sections[18])) &&
        (sections.size() <= 19 || isValidSectionBlock(sections[19])) &&
        (sections.size() <= 20 || isValidSectionBlock(sections[20])) &&
        (sections.size() <= 21 || isValidSectionBlock(sections[21])) &&
        (sections.size() <= 22 || isValidSectionBlock(sections[22])) &&
        (sections.size() <= 23 || isValidSectionBlock(sections[23]));
    }

    function isValidSectionBlocks24To31(sections) {
      return (sections.size() <= 24 || isValidSectionBlock(sections[24])) &&
        (sections.size() <= 25 || isValidSectionBlock(sections[25])) &&
        (sections.size() <= 26 || isValidSectionBlock(sections[26])) &&
        (sections.size() <= 27 || isValidSectionBlock(sections[27])) &&
        (sections.size() <= 28 || isValidSectionBlock(sections[28])) &&
        (sections.size() <= 29 || isValidSectionBlock(sections[29])) &&
        (sections.size() <= 30 || isValidSectionBlock(sections[30])) &&
        (sections.size() <= 31 || isValidSectionBlock(sections[31]));
    }

    function isValidResumeSections(sections) {
      return sections is list &&
        sections.size() <= 32 &&
        isValidSectionBlocks0To7(sections) &&
        (sections.size() <= 8 || isValidSectionBlocks8To15(sections)) &&
        (sections.size() <= 16 || isValidSectionBlocks16To23(sections)) &&
        (sections.size() <= 24 || isValidSectionBlocks24To31(sections));
    }

    function isValidResumeShape(resume) {
      return resume is map &&
        resume.settings is map &&
        isValidSettings(resume.settings) &&
        isValidResumeCollection(resume.education) &&
        isValidResumeCollection(resume.experience) &&
        isValidResumeCollection(resume.skills) &&
        isValidResumeCollection(resume.projects) &&
        isValidResumeCollection(resume.certifications) &&
        isValidResumeCollection(resume.volunteering) &&
        isValidResumeCollection(resume.leadership) &&
        isValidResumeCollection(resume.languages) &&
        isValidResumeCollection(resume.awards) &&
        isValidResumeCollection(resume.publications) &&
        (!resume.keys().hasAny(['sections']) || isValidResumeSections(resume.sections));
    }

    function isValidWorkspace(data) {
      return data.keys().hasOnly([
        'schemaVersion',
        'activeResumeId',
        'resumeIds',
        'meta',
        'updatedAt',
        'version',
        'deviceId',
        'sessionId'
      ]) &&
      data.schemaVersion == 1 &&
      isString(data.activeResumeId) &&
      data.resumeIds is list &&
      data.resumeIds.size() > 0 &&
      data.resumeIds.size() <= 50 &&
      data.activeResumeId in data.resumeIds &&
      isValidMeta(data.meta, data.resumeIds) &&
      isString(data.updatedAt) &&
      data.version is int &&
      isString(data.deviceId) &&
      isNullableString(data.sessionId);
    }

    function isValidResumeDoc(data, resumeId) {
      return data.keys().hasOnly([
        'schemaVersion',
        'resumeId',
        'name',
        'template',
        'sectionOrder',
        'resume',
        'savedAt',
        'updatedAt',
        'version',
        'deviceId',
        'sessionId',
        'deletedAt'
      ]) &&
      data.schemaVersion == 1 &&
      data.resumeId == resumeId &&
      isString(data.name) &&
      data.name.size() > 0 &&
      data.name.size() <= 25 &&
      isValidTemplate(data.template) &&
      isValidSectionOrder(data.sectionOrder) &&
      isValidResumeShape(data.resume) &&
      isString(data.savedAt) &&
      isString(data.updatedAt) &&
      data.version is int &&
      isString(data.deviceId) &&
      isNullableString(data.sessionId) &&
      isNullableString(data.deletedAt);
    }

    match /users/{uid}/workspace/main {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidWorkspace(request.resource.data);
      allow delete: if false;
    }

    match /users/{uid}/resumes/{resumeId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidResumeDoc(request.resource.data, resumeId);
      allow delete: if isOwner(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
