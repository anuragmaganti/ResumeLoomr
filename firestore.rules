rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isString(value) {
      return value is string;
    }

    function isNullableString(value) {
      return value == null || value is string;
    }

    function isValidTemplate(value) {
      return value in ['executive', 'compact'];
    }

    function isValidSetting(value) {
      return value is int && value >= -5 && value <= 5;
    }

    function isValidSummaryWidth(value) {
      return value is int && value >= 75 && value <= 100;
    }

    function isValidSeparatorTone(value) {
      return value is int && value >= 0 && value <= 100;
    }

    function isValidSeparatorWeight(value) {
      return value is int && value >= 1 && value <= 5;
    }

    function isValidSeparatorGap(value) {
      return value is int && value >= -5 && value <= 5;
    }

    function isValidSectionSeparatorPosition(value) {
      return value is string && value in ['aboveSectionName', 'belowSectionName'];
    }

    function isValidPersonalAlignment(value) {
      return value is string && value in ['template', 'left', 'center'];
    }

    function isValidPersonalHeaderOrder(value) {
      return value is list &&
        value.size() == 2 &&
        value.hasAll(['headline', 'contact']) &&
        value.hasOnly(['headline', 'contact']);
    }

    function isValidPersonalContactOrder(value) {
      return value is list &&
        value.size() == 7 &&
        value.hasAll([
          'location',
          'phone',
          'email',
          'linkedinUrl',
          'githubUrl',
          'portfolioUrl',
          'customField'
        ]) &&
        value.hasOnly([
          'location',
          'phone',
          'email',
          'linkedinUrl',
          'githubUrl',
          'portfolioUrl',
          'customField'
        ]);
    }

    function isValidSettings(settings) {
      return settings is map &&
        settings.keys().hasOnly([
          'textSize',
          'horizontalMargins',
          'verticalMargins',
          'lineSpacing',
          'sectionSpacing',
          'entrySpacing',
          'headingSize',
          'nameSize',
          'summaryWidthPercent',
          'personalSeparatorTone',
          'sectionSeparatorTone',
          'personalSeparatorWeight',
          'sectionSeparatorWeight',
          'personalSeparatorGap',
          'sectionSeparatorGap',
          'sectionSeparatorPosition',
          'personalContactOrder',
          'personalAlignment',
          'personalHeaderOrder'
        ]) &&
        isValidSetting(settings.textSize) &&
        isValidSetting(settings.horizontalMargins) &&
        isValidSetting(settings.verticalMargins) &&
        isValidSetting(settings.lineSpacing) &&
        isValidSetting(settings.sectionSpacing) &&
        isValidSetting(settings.entrySpacing) &&
        isValidSetting(settings.headingSize) &&
        isValidSetting(settings.nameSize) &&
        (
          !settings.keys().hasAny(['summaryWidthPercent']) ||
          isValidSummaryWidth(settings.summaryWidthPercent)
        ) &&
        (
          !settings.keys().hasAny(['personalSeparatorTone']) ||
          isValidSeparatorTone(settings.personalSeparatorTone)
        ) &&
        (
          !settings.keys().hasAny(['sectionSeparatorTone']) ||
          isValidSeparatorTone(settings.sectionSeparatorTone)
        ) &&
        (
          !settings.keys().hasAny(['personalSeparatorWeight']) ||
          isValidSeparatorWeight(settings.personalSeparatorWeight)
        ) &&
        (
          !settings.keys().hasAny(['sectionSeparatorWeight']) ||
          isValidSeparatorWeight(settings.sectionSeparatorWeight)
        ) &&
        (
          !settings.keys().hasAny(['personalSeparatorGap']) ||
          isValidSeparatorGap(settings.personalSeparatorGap)
        ) &&
        (
          !settings.keys().hasAny(['sectionSeparatorGap']) ||
          isValidSeparatorGap(settings.sectionSeparatorGap)
        ) &&
        (
          !settings.keys().hasAny(['sectionSeparatorPosition']) ||
          isValidSectionSeparatorPosition(settings.sectionSeparatorPosition)
        ) &&
        (
          !settings.keys().hasAny(['personalContactOrder']) ||
          isValidPersonalContactOrder(settings.personalContactOrder)
        ) &&
        (
          !settings.keys().hasAny(['personalAlignment']) ||
          isValidPersonalAlignment(settings.personalAlignment)
        ) &&
        (
          !settings.keys().hasAny(['personalHeaderOrder']) ||
          isValidPersonalHeaderOrder(settings.personalHeaderOrder)
        );
    }

    function isValidSampleDisplay(sampleDisplay) {
      return sampleDisplay is map &&
        sampleDisplay.keys().hasOnly([
          'hasStarted',
          'showInformation',
          'entryBindings'
        ]) &&
        sampleDisplay.hasStarted is bool &&
        sampleDisplay.showInformation is bool &&
        (
          !sampleDisplay.keys().hasAny(['entryBindings']) ||
          sampleDisplay.entryBindings is map
        );
    }

    function isValidMeta(meta, resumeIds) {
      return meta is map &&
        meta.keys().hasAll(resumeIds) &&
        meta.keys().hasOnly(resumeIds);
    }

    function isValidPersonal(personal) {
      return personal is map &&
        personal.keys().hasOnly([
          'name',
          'headline',
          'location',
          'phone',
          'email',
          'linkedinUrl',
          'portfolioUrl',
          'githubUrl',
          'customField',
          'aboutMe'
        ]) &&
        isString(personal.name) &&
        isString(personal.headline) &&
        isString(personal.location) &&
        isString(personal.phone) &&
        isString(personal.email) &&
        isString(personal.linkedinUrl) &&
        isString(personal.portfolioUrl) &&
        isString(personal.githubUrl) &&
        isString(personal.customField) &&
        isString(personal.aboutMe);
    }

    function isValidSections(sections) {
      return sections is list &&
        sections.size() > 0 &&
        sections.size() <= 100;
    }

    function isValidResumeShape(resume) {
      return resume is map &&
        resume.keys().hasOnly(['personal', 'settings', 'sampleDisplay', 'sections']) &&
        isValidPersonal(resume.personal) &&
        isValidSettings(resume.settings) &&
        (!('sampleDisplay' in resume) || isValidSampleDisplay(resume.sampleDisplay)) &&
        isValidSections(resume.sections);
    }

    function isValidWorkspace(data) {
      return data.keys().hasOnly([
        'schemaVersion',
        'activeResumeId',
        'resumeIds',
        'meta',
        'updatedAt',
        'version',
        'deviceId',
        'sessionId'
      ]) &&
      data.schemaVersion == 1 &&
      isString(data.activeResumeId) &&
      data.resumeIds is list &&
      data.resumeIds.size() > 0 &&
      data.resumeIds.size() <= 100 &&
      data.activeResumeId in data.resumeIds &&
      isValidMeta(data.meta, data.resumeIds) &&
      isString(data.updatedAt) &&
      data.version is int &&
      isString(data.deviceId) &&
      isNullableString(data.sessionId);
    }

    function isValidResumeDoc(data, resumeId) {
      return data.keys().hasOnly([
        'schemaVersion',
        'resumeId',
        'name',
        'template',
        'resume',
        'savedAt',
        'updatedAt',
        'version',
        'deviceId',
        'sessionId',
        'deletedAt'
      ]) &&
      data.schemaVersion == 1 &&
      data.resumeId == resumeId &&
      isString(data.name) &&
      data.name.size() > 0 &&
      data.name.size() <= 50 &&
      isValidTemplate(data.template) &&
      isValidResumeShape(data.resume) &&
      isString(data.savedAt) &&
      isString(data.updatedAt) &&
      data.version is int &&
      isString(data.deviceId) &&
      isNullableString(data.sessionId) &&
      isNullableString(data.deletedAt);
    }

    match /users/{uid}/workspace/main {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidWorkspace(request.resource.data);
      allow delete: if false;
    }

    match /users/{uid}/resumes/{resumeId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidResumeDoc(request.resource.data, resumeId);
      allow delete: if isOwner(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
